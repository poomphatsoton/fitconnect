<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <!-- 通用顶部栏 -->
    <include layout="@layout/layout_top_bar"/>

    <!-- 主内容滚动区 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 教练信息卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical"
                android:elevation="2dp">
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:contentDescription="Trainer avatar"
                    android:src="@drawable/ic_person"
                    android:scaleType="centerCrop"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="16dp">
                    <TextView
                        android:id="@+id/tv_trainer_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="John Smith"
                        android:textSize="22sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tv_trainer_bio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Certified personal trainer with 10 years of experience"
                        android:textSize="16sp"
                        android:textColor="#6C757D"
                        android:layout_marginTop="4dp"/>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="strength"
                            android:background="#E9ECEF"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:textSize="12sp"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="cardio"
                            android:background="#E9ECEF"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:textSize="12sp"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="flexibility"
                            android:background="#E9ECEF"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 两个创建按钮（添加id，修复点击） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_create_exercise"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Create Exercise"
                    android:drawableTop="@drawable/ic_add"
                    android:backgroundTint="#0F172A"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="8dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_create_workout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Create Workout"
                    android:drawableTop="@drawable/ic_add"
                    android:backgroundTint="#0F172A"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="8dp"/>
            </LinearLayout>

            <!-- Overview 卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Overview"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Trainees"
                        android:src="@drawable/ic_group"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Active Trainees"
                        android:textSize="16sp"
                        android:paddingStart="12dp"/>
                    <TextView
                        android:id="@+id/tv_active_trainees"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Exercises"
                        android:src="@drawable/ic_list"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Exercises"
                        android:textSize="16sp"
                        android:paddingStart="12dp"/>
                    <TextView
                        android:id="@+id/tv_exercises"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Workouts"
                        android:src="@drawable/ic_fitness"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Workouts"
                        android:textSize="16sp"
                        android:paddingStart="12dp"/>
                    <TextView
                        android:id="@+id/tv_workouts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_pending_requests"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1 Pending Request"
                    android:drawableStart="@drawable/ic_notification"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="#000000"
                    android:strokeWidth="1"
                    android:strokeColor="#E2E8F0"
                    app:cornerRadius="8dp"/>
            </LinearLayout>

            <!-- No Trainees 卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#FFFFFF"
                android:padding="40dp"
                android:elevation="2dp">
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:contentDescription="No trainees"
                    android:src="@drawable/ic_group"
                    android:alpha="0.5"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No trainees yet"
                    android:textSize="18sp"
                    android:textColor="#6C757D"
                    android:layout_marginTop="16dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trainees can request to join you from the Trainers list"
                    android:textSize="14sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>